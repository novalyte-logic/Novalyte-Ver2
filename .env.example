# Browser-safe Supabase config. These values are exposed to the client bundle.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Server-only Supabase secret used by Express routes for privileged reads/writes.
# Never expose this key to the client bundle.
SUPABASE_SECRET_KEY="sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional server aliases if you want client and server env vars separated.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Gemini server-side AI key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_FAST_MODEL="gemini-3-flash-preview"
GEMINI_RESEARCH_MODEL="gemini-3.1-pro-preview"
AI_REQUEST_TIMEOUT_MS="15000"
AI_MAX_RETRIES="2"

# Public app URL for OAuth redirects, CORS, and generated absolute links.
APP_URL="http://localhost:3000"

# Optional comma-separated origins allowed to call the API.
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Sensitive admin actions in /api/admin still require a confirmation code.
ADMIN_ACTION_CONFIRMATION_CODE="1750"
ADMIN_ALLOWED_EMAILS="ops@novalyte.io,admin@novalyte.io"
ADMIN_EMAIL="ops@novalyte.io"

# Server-side correspondence and alerting.
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
NOTIFICATION_TIMEOUT_MS="4000"
NOTIFICATION_MAX_RETRIES="2"

# SMTP settings used for secure admin correspondence delivery.
# If you route Supabase Auth email through your own SMTP provider, keep those credentials in secure server-side secret management as well.
EMAIL_FROM_ADDRESS="Novalyte AI <no-reply@novalyte.io>"
EMAIL_SMTP_HOST="smtp.mailprovider.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_SECURE="false"
EMAIL_SMTP_USER="smtp-user"
EMAIL_SMTP_PASSWORD="smtp-password"
EMAIL_CONNECTION_TIMEOUT_MS="5000"

# Logging and release metadata.
LOG_LEVEL="info"
TRUST_PROXY="true"
ENABLE_REQUEST_LOGGING="true"
ENABLE_ANALYTICS_INGEST="true"
ENABLE_CLIENT_ERROR_INGEST="true"
RELEASE_VERSION="local-dev"

# Optional client/server error monitoring endpoint configuration.
SENTRY_DSN=""

# Render uses this for runtime binding automatically.
PORT="3000"

# Local Supabase Auth note:
# add http://localhost:3000 and http://127.0.0.1:3000 to Supabase Auth redirect URLs,
# configure Google and LinkedIn providers in Supabase Auth before using social sign-in locally,
# and set the email template to include {{ .Token }} if you want a 6-digit email access-code flow.
